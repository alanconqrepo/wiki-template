# =============================================
#  Wiki.js Enterprise — Variables d'environnement
#  Emplacement : /opt/wikijs/.env
#
#  Usage : cp .env.example .env
#          puis remplir les valeurs manquantes
# =============================================

# ----- Wiki.js -----
WIKIJS_DB_NAME=wikijs
WIKIJS_DB_USER=wikijs
WIKIJS_DB_PASS=              # Générer : openssl rand -base64 32

# ----- Elasticsearch -----
ES_JAVA_OPTS=-Xms1g -Xmx1g

# ----- Keycloak OIDC (instance existante) -----
# Ces valeurs sont configurées dans l'UI Wiki.js Admin → Authentication.
# Elles sont listées ici à titre de référence uniquement.
KC_INTERNAL_URL=http://keycloak:8080
KC_EXTERNAL_URL=http://localhost:8080
KC_REALM=enterprise
KC_CLIENT_ID=wikijs
KC_CLIENT_SECRET=            # Récupérer depuis Keycloak après création du client

# ----- Azure Blob Storage -----
AZURE_STORAGE_ACCOUNT=stwikijsassets
AZURE_STORAGE_KEY=           # Copier key1 depuis le portail Azure
AZURE_STORAGE_CONTAINER=wiki-assets

# ----- Git Sync -----
WIKIJS_GIT_REPO_URL=git@github.com:<org>/wiki-content.git
WIKIJS_GIT_BRANCH=main

# ----- Intégration Open WebUI -----
WIKIJS_API_URL=http://wikijs:3000/graphql
WIKIJS_API_KEY=              # Générer après le premier setup Wiki.js
